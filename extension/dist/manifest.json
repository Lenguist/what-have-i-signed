{
  "manifest_version": 3,
  "name": "What Have I Signed?",
  "version": "0.1.0",
  "description": "Save Terms & Conditions when you accept them. Come back later to chat with AI about what you agreed to.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "What Have I Signed?"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "externally_connectable": {
    "matches": [
      "https://what-have-i-signed.vercel.app/*",
      "http://localhost:3000/*"
    ]
  }
}
